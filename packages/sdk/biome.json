{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "extends": ["../../biome.json"],
  "files": {},
  "linter": {
    "rules": {
      "style": {
        "noUselessElse": "off",
        "noNonNullAssertion": "off",
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "paths": {
              "@sodax/sdk": "Import from '@sodax/types' (or local modules) inside the SDK; do not import the package entry '@sodax/sdk'."
            }
          }
        }
      },
      "suspicious": {
        "noExplicitAny": "off",
        "noFallthroughSwitchClause": "error"
      },
      "complexity": {
        "noStaticOnlyClass": "off"
      },
      "correctness": {
        "noUnusedFunctionParameters": "off"
      }
    },
    "ignore": []
  }
}
