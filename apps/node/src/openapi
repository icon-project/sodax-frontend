      description: Authenticates a user by verifying their BIP322 signature and creates a wallet with JWT tokens
      parameters: []
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/AuthenticateDto'
      responses:
        '200':
          description: User authenticated successfully
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/BaseResponseDto'
        '400':
          description: Invalid signature, invalid address, or authentication failed
          content:
            application/json:
              schema:
                type: object
                properties:
                  code:
                    type: string
                    example: '4001'
                  message:
                    type: string
                    example: auth.signatureVerificationFailed
                  details:
                    type: string
