openapi: 3.0.0
paths:
  /api/transactions:
    post:
      operationId: TransactionController_create
      summary: Create transaction
      parameters: []
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/CreateTransactionDto'
            examples:
              withdraw:
                value:
                  type: withdraw
                  params:
                    userAddress: tb1qg5s9rdd9ddhacql3upd7ntzrexp3kn95v4hndm
                    amount: '10000'
                    tokenId: '2904354:3119'
                    withdrawTo: tb1qg5s9rdd9ddhacql3upd7ntzrexp3kn95v4hndm
                    receipt:
                      amount: '10000'
                      isToken0: true
                      fee: 30
                      token0Address: '0xabc'
                      token1Address: '0xabc'
                      hookAddress: '0xabc'
                      tickSpacing: 1000
              initLP:
                value:
                  type: init-liquidity-pool
                  params:
                    userAddress: tb1qg5s9rdd9ddhacql3upd7ntzrexp3kn95v4hndm
                    token0Id: '0:0'
                    token1Id: '2904354:3119'
                    amount0: '10000'
                    amount1: '10000'
                    initPrice: '1000'
                    upperTick: '100'
                    lowerTick: '-100'
                    feeRate: 30
                    tickSpacing: 1000
                    receipt:
                      amount: '10000'
                      isToken0: true
                      fee: 30
                      token0Address: '0xabc'
                      token1Address: '0xabc'
                      hookAddress: '0xabc'
                      tickSpacing: 1000
              provideLiquidity:
                value:
                  type: provide-liquidity
                  params:
                    userAddress: tb1qg5s9rdd9ddhacql3upd7ntzrexp3kn95v4hndm
                    token0Id: '0:0'
                    token1Id: '2904354:3119'
                    amount0: '10000'
                    amount1: '10000'
                    upperTick: '100'
                    lowerTick: '-100'
                    feeRate: 30
                    tickSpacing: 10000
                    hookSeq: 1
                    receipt:
                      amount: '10000'
                      isToken0: true
                      fee: 30
                      token0Address: '0xabc'
                      token1Address: '0xabc'
                      hookAddress: '0xabc'
                      tickSpacing: 1000
              increaseLP:
                value:
                  type: increase-liquidity
                  params:
                    userAddress: tb1qg5s9rdd9ddhacql3upd7ntzrexp3kn95v4hndm
                    nftId: '1'
                    amount0: '10000'
                    amount1: '10000'
                    token0Id: '0:0'
                    token1Id: '2904354:3119'
                    receipt:
                      amount: '10000'
                      isToken0: true
                      fee: 30
                      token0Address: '0xabc'
                      token1Address: '0xabc'
                      hookAddress: '0xabc'
                      tickSpacing: 1000
              swap:
                value:
                  type: swap
                  params:
                    userAddress: tb1qg5s9rdd9ddhacql3upd7ntzrexp3kn95v4hndm
                    tokens:
                      - '0:0'
                      - '2904354:3119'
                    amountIn: '10000'
                    amountOut: '10000'
                    feeRates:
                      - 3000
                    isExactIn: true
                    tickSpacings:
                      - 10000
                    hookSeqs:
                      - 1
                    receipt:
                      amount: '10000'
                      isToken0: true
                      fee: 30
                      token0Address: '0xabc'
                      token1Address: '0xabc'
                      hookAddress: '0xabc'
                      tickSpacing: 1000
              withdrawLiquidity:
                value:
                  type: withdraw-liquidity
                  params:
                    userAddress: tb1qg5s9rdd9ddhacql3upd7ntzrexp3kn95v4hndm
                    liquidityValue: '10000'
                    nftId: '1'
                    amount0: '10000'
                    amount1: '10000'
                    token0Id: '0:0'
                    token1Id: '2904354:3119'
                    scVersion: v4
                    receipt:
                      amount: '10000'
                      isToken0: true
                      fee: 30
                      token0Address: '0xabc'
                      token1Address: '0xabc'
                      hookAddress: '0xabc'
                      tickSpacing: 1000
              collectFee:
                value:
                  type: collect-fee
                  params:
                    userAddress: tb1qg5s9rdd9ddhacql3upd7ntzrexp3kn95v4hndm
                    nftId: '1'
                    amount0: '10000'
                    amount1: '10000'
                    token0Id: '0:0'
                    token1Id: '2904354:3119'
                    scVersion: v4
                    receipt:
                      amount: '10000'
                      isToken0: true
                      fee: 30
                      token0Address: '0xabc'
                      token1Address: '0xabc'
                      hookAddress: '0xabc'
                      tickSpacing: 1000
              renewUtxo:
                value:
                  type: renew-utxo
                  params:
                    userAddress: tb1qg5s9rdd9ddhacql3upd7ntzrexp3kn95v4hndm
                    txIdVouts:
                      - txId1:vout1
                      - txId2:vout2
                      - txId3:vout3
      responses:
        '201':
          description: ''
      tags:
        - transactions
      security:
        - bearer: []
  /api/transactions/sign:
    post:
      operationId: TransactionController_signAndBroadcast
